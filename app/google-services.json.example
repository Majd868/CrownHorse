{
  "_comment": "Replace this file with your actual google-services.json downloaded from Firebase Console.",
  "_instructions": [
    "1. Go to https://console.firebase.google.com/",
    "2. Create a new project or select an existing one",
    "3. Add an Android app with package name: com.crownhorse.app",
    "4. Download google-services.json",
    "5. Place it in the app/ directory (replacing this file)",
    "6. Enable Authentication (Email/Password), Firestore, Storage, and Cloud Messaging"
  ],
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "project_id": "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.appspot.com"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "YOUR_MOBILESDK_APP_ID",
        "android_client_info": {
          "package_name": "com.crownhorse.app"
        }
      },
      "api_key": [{"current_key": "YOUR_API_KEY"}],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
